{
  "appId": "com.awoo-co.catchat",
  "productName": "Catchat",
  "directories": {
    "buildResources": "resources",
    "output": "dist"
  },
  "files": [
    "assets/**/*",
    "build/**/*",
    "capacitor.config.*",
    "app/**/*"
  ],
  "publish": {
    "provider": "github"
  },
  "nsis": {
    "allowElevation": true,
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  },
  "win": {
    "target": ["nsis"],
    "icon": "assets/icon_only.ico"
  },
  "mac": {
    "category": "public.app-category.utilities",
    "target": ["dmg"]
  },
  "linux": {
    "target": ["AppImage", "deb", "rpm"],
    "category": "Utility"
  }
}